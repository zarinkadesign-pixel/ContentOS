# ── Планировщик ───────────────────────────────────────────────────────────────
POST_INTERVAL_MIN=60          # Минимум минут между постами одного объявления
POST_INTERVAL_MAX=240         # Максимум (рандом в этом диапазоне)
ACTIVE_HOUR_START=9           # Начало публикаций (UTC+5, Астана)
ACTIVE_HOUR_END=21            # Конец публикаций
REPOST_INTERVAL_HOURS=24      # Через сколько часов повторить публикацию
MAX_POSTS_PER_DAY=30          # Лимит постов в день
POST_DELAY_SECONDS=3          # Пауза между постами в одном тике

# ── Комиссии ─────────────────────────────────────────────────────────────────
